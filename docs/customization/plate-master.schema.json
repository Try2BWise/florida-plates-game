{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gorillagrin.com/schemas/plates/plate-master.schema.json",
  "title": "Plate Master Dataset",
  "description": "Authoring dataset for a state-specific license plate game pack. Designed for human curation and AI-assisted scraping before runtime generation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedDate",
    "description",
    "sourceFiles",
    "plates"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "type": "string",
      "description": "Optional state or pack name, such as Florida or Mississippi."
    },
    "generatedDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "YYYY-MM-DD"
    },
    "description": {
      "type": "string"
    },
    "sourceFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "plates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plate"
      }
    }
  },
  "$defs": {
    "category": {
      "type": "string",
      "enum": [
        "Accessibility",
        "Civic & Causes",
        "Commercial & Fleet",
        "Education & Culture",
        "Government & Official",
        "Health & Family",
        "Historical & Antique",
        "Military Honors & History",
        "Military Service",
        "Motorcycle Plates",
        "Nature & Wildlife",
        "Professional Sports",
        "Public Service",
        "Special Use",
        "Sports & Recreation",
        "Standard Plates",
        "Travel & Tourism",
        "Universities"
      ]
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "remoteUrl"
      ],
      "properties": {
        "path": {
          "type": "string",
          "description": "Preferred local asset path such as plates/example.png. May be empty during early scrape passes."
        },
        "remoteUrl": {
          "type": [
            "string",
            "null"
          ],
          "description": "Original image source URL when known."
        }
      }
    },
    "metadataBlob": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sponsorCandidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidate"
          }
        },
        "noteCandidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidate"
          }
        },
        "sourceCategories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rawNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "filenames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "urls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "priority",
        "value"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "sourceId"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "sourceId": {
          "type": [
            "string",
            "number"
          ]
        },
        "versionId": {
          "type": "string"
        },
        "filename": {
          "type": "string"
        },
        "section": {
          "type": "string"
        },
        "imageKey": {
          "type": "string"
        },
        "variant": {
          "type": "string"
        }
      }
    },
    "plate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slug",
        "name",
        "displayName",
        "baseName",
        "variantLabel",
        "plateType",
        "isCurrent",
        "isActive",
        "category",
        "image",
        "sponsor",
        "notes",
        "searchTerms",
        "variantOf",
        "relatedPlates"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "Stable logical/variant plate identifier."
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "description": "Primary logical name. For motorcycle plates, the runtime generator may append (Motorcycle)."
        },
        "displayName": {
          "type": "string",
          "description": "Player-facing label, may include variant wording."
        },
        "baseName": {
          "type": "string",
          "description": "Logical plate family name without variant suffixes."
        },
        "variantLabel": {
          "type": [
            "string",
            "null"
          ],
          "description": "Examples: Legacy, Current, Motorcycle."
        },
        "plateType": {
          "type": "string",
          "description": "Usually license_plate."
        },
        "isCurrent": {
          "type": "boolean"
        },
        "isActive": {
          "type": "boolean"
        },
        "category": {
          "$ref": "#/$defs/category"
        },
        "image": {
          "$ref": "#/$defs/image"
        },
        "sponsor": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadataBlob": {
          "$ref": "#/$defs/metadataBlob"
        },
        "searchTerms": {
          "type": "array",
          "description": "Lowercase terms players are likely to search for.",
          "items": {
            "type": "string"
          }
        },
        "variantOf": {
          "type": [
            "string",
            "null"
          ],
          "description": "ID of the parent plate when this record is a variant."
        },
        "relatedPlates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sourceRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      }
    }
  }
}
